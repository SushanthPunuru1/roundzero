# Copy to .env and fill in real values. Never commit .env.

# Postgres (Neon) — pooled + direct connection strings
DATABASE_URL=
DIRECT_URL=

# Better Auth — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth — magic link email
RESEND_API_KEY=

# Better Auth core
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# lab-broker (local-only — see lab-broker/README.md and docs/DECISIONS.md 027).
# Leave unset to keep /app/lab dark; the rest of the app builds/runs fine without it.
LAB_BROKER_URL=
